# Pins indentation, charset, and line endings so files do not drift between editors.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4

[*.{ts,tsx,js,jsx,json,css,html,yml,yaml,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false   # two trailing spaces is a hard line break in Markdown

[Makefile]
indent_style = tab
