# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Node / frontend build tooling (built dist IS committed; node_modules is not)
node_modules/
app/frontend/.vite/

# Per-machine + secrets (never in the repo)
*.local
.env

# OS junk
.DS_Store
Thumbs.db

# Launcher-provisioned runtimes (bootstrapped on the user's machine, not committed)
/runtime/
/tools/uv*
/tools/mingit/

# PyInstaller / launcher build outputs (packaging/build_exe.ps1 + the release CI produce these)
/dist/
/build/
/packaging/mingit/
/packaging/webview2/
/mingit.zip

# Superpowers SDD scratch (ledger, task briefs, review packages)
.superpowers/

# Developer-local Claude Code settings + personal commands (ledger hook references a private path)
.claude/

# Claude instructions: local only, never pushed (owner directive)
/CLAUDE.md

# AI-workflow design docs: local only, never pushed (owner directive)
docs/superpowers/
docs/research/

# GSD spec-driven-development working state: local only, never pushed (like docs/superpowers/)
.planning/
.gsd/

# Derived, never-committed library artifacts (the SQLite indexes are in-memory; the enrich
# cache is the one on-disk derived dir, written beside the in-repo library at <repo>/)
/.stockroom-enrich-cache/
/.stockroom-previews/
.firecrawl/
# The derived STM32 pinout/spec index (config_dir()/stm/index.sqlite by default,
# outside the repo already; these are belt-and-suspenders for any in-repo fallback path)
/.stockroom-stm-index/
*.stm-index.sqlite
# Derived Altium data source (regenerated from JSON like the SQLite index; the .DbLib IS committed)
libraries/*/altium/*.xlsx

# Agent tooling: installed skills + SuperDesign workspace (never committed)
.agents/
.superdesign/
/skills-lock.json

# S8 cold-rebuild harness run outputs (local only)
scripts/out/

# Untracked, kept local (out of the repo, still on disk). library-v2.html stays tracked.
docs/mockups/accent-direction.html
docs/mockups/layout-direction.html
docs/mockups/library-app.html
docs/mockups/library-combined.html
docs/mockups/projects.html
docs/mockups/render-library-parts.html
docs/Stockroom-Knowledge-Transfer.md
docs/FINALE_SAUCE_BOM.md
docs/FINALE_SAUCE_BOM.xlsx
docs/FINALE_SAUCE_SOURCE.md
# Superseded root launcher; the shipped one is stockroom.launcher (see packaging/).
/launcher/
tests/backend/api/test_launcher.py
tests/backend/api/test_gitshim.py

.planning/
.gsd/
